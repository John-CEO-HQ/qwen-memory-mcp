# Phase 2 deployment verification (copy to .env.integration; never commit)
# Load together with .env:  set -a && source .env && source .env.integration && set +a

# Public HTTPS base URL of your deployed server (no trailing slash)
DEPLOYED_MCP_URL=

# Same bearer token configured on ECS/Function Compute
MCP_AUTH_TOKEN=

# Optional alias for verify scripts
# DEPLOYED_MCP_AUTH_TOKEN=

# Stable user id for integration / smoke tests
INTEGRATION_TEST_USER_ID=integration-test-user
