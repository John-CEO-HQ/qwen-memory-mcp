# ---------------------------------------------------------------------------
# Qwen Memory MCP - example environment
# Copy to .env and fill in. NEVER commit a real .env.
# ---------------------------------------------------------------------------

# --- Qwen / Alibaba Cloud Model Studio (DashScope) ---------------------------
# Get a key from Alibaba Cloud Model Studio (DashScope). This is a platform
# secret: it lives only on the backend, never in a client or on a user device.
QWEN_API_KEY=

# DashScope OpenAI-compatible base URL.
# International (Singapore): https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Mainland China (Beijing):  https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Qwen models used by the memory intelligence layer.
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3

# Force the offline deterministic intelligence (no network). Useful for the
# demo and CI. If QWEN_API_KEY is empty, fake mode is enabled automatically.
USE_FAKE_QWEN=

# --- Storage -----------------------------------------------------------------
# memory | file | mysql
MEMORY_STORE=file
# Path for the file store (ignored for memory/mysql).
MEMORY_FILE_PATH=./.data/memories.json

# Alibaba Cloud RDS / PolarDB MySQL (used when MEMORY_STORE=mysql).
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=qwen_memory

# --- Transport ---------------------------------------------------------------
# stdio | http
MCP_TRANSPORT=stdio
# HTTP port when MCP_TRANSPORT=http (Function Compute / ECS).
PORT=8080
# Optional bearer token required on the HTTP transport. When John CEO mounts
# this server it hands each user a scoped URL carrying this token.
MCP_AUTH_TOKEN=

# --- Forgetting / decay tuning (optional; sane defaults baked in) ------------
# Half-life in days for memory decay.
MEMORY_DECAY_HALF_LIFE_DAYS=14
# Cosine similarity at/above which two memories are consolidated.
MEMORY_CONSOLIDATE_SIMILARITY=0.86
# Memories scoring below this (after decay) and below the salience floor are forgotten.
MEMORY_RETENTION_THRESHOLD=0.12
# Salience at/above which a memory is always kept regardless of decay.
MEMORY_SALIENCE_FLOOR=0.8
